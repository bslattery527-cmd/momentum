# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/momentum?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-string-at-least-64-characters-long-xxxxxxxxxx"
JWT_REFRESH_SECRET="change-me-to-a-different-random-string-at-least-64-characters-long"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Apple Sign-In
APPLE_CLIENT_ID="com.your.app.service-id"
APPLE_TEAM_ID="YOUR_TEAM_ID"
APPLE_KEY_ID="YOUR_KEY_ID"
APPLE_PRIVATE_KEY="base64-encoded-p8-private-key"

# AWS S3 / Cloudflare R2
S3_BUCKET_NAME="momentum-uploads"
S3_REGION="us-east-1"
S3_ENDPOINT=""
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
CDN_BASE_URL="https://cdn.momentum.app"

# Expo Push Notifications
EXPO_ACCESS_TOKEN="your-expo-access-token"

# Server
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"
